{%- if RUN_LIMESURVEY %}
- name: limesurvey-apacheconf
  files:
    - plugins/limesurvey/apps/etc/apache2/apache2.conf
  options:
    labels:
        app.kubernetes.io/name: limesurvey
{%- if LIMESURVEY_CONFIGPHP %}
- name: limesurvey-configphp
  files:
    - plugins/limesurvey/apps/var/www/html/application/config/config.php
  options:
    labels:
        app.kubernetes.io/name: limesurvey
{%- endif %}
{%- endif %}
